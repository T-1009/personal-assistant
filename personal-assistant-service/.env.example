# Personal Assistant Service — the single user-facing configuration catalog.
#
# Local:
#   cp .env.example .env
#
# Production:
#   Inject the same variable names through AgentArts Runtime / CI/CD.
#
# Secret values do NOT belong in this file. Configure them in AgentArts
# Identity using the provider names documented below.
#
# Convention:
# - Commented entries already have the shown default in app/settings.py.
# - Uncomment only values you want to override.
# - Entries without an application default would be uncommented and marked
#   required.

# =============================================================================
# Application
# =============================================================================

# Default: INFO. Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# =============================================================================
# LLM
# =============================================================================

# Built-in Provider catalog key. Default: deepseek.
# LLM_PROVIDER=deepseek

# Model name deployed by the selected Provider. Default: deepseek-v4-pro.
# LLM_MODEL=deepseek-v4-pro

# Optional OpenAI-compatible endpoint override.
# Default: use the built-in endpoint for LLM_PROVIDER.
# LLM_BASE_URL=https://api.example.com/v1

# AgentArts Identity API Key provider name. This is a reference, not a Secret.
# Create this provider in AgentArts Identity and store the real API key there.
# Default: DEEPSEEK_API_KEY.
# LLM_CREDENTIAL_PROVIDER=DEEPSEEK_API_KEY

# Request timeout is an application reliability guard, not a model sampling
# parameter. Sampling and output limits use the Provider/model defaults.
# LLM_TIMEOUT_SECONDS=60

# Process-scoped compiled Agent reuse window. When the TTL expires, the next
# request fetches the current API Key and atomically rebuilds the Agent Bundle.
# Default: 300 seconds. Must be greater than zero.
# LLM_AGENT_BUNDLE_TTL_SECONDS=300

# =============================================================================
# Persistence — choose at most one
# =============================================================================

# Local persistent checkpoint database.
# SQLITE_DB_PATH=.data/checkpoints.db

# Production PostgreSQL checkpoint database.
# POSTGRES_DSN=postgresql://user:password@host:5432/personal_assistant

# When both are empty, the service uses an in-memory Checkpointer.

# =============================================================================
# AgentArts Identity integration references
# =============================================================================

# Gitee OAuth2 provider name. Default: gitee-provider.
# GITEE_PROVIDER_NAME=gitee-provider

# Huawei Cloud IAM STS provider configuration. Defaults shown below.
# IAM_USERS_PROVIDER_NAME=iam-users-readonly
# IAM_USERS_AGENCY_SESSION_NAME=personal-assistant-iam-users-readonly
# IAM_USERS_REGION=cn-southwest-2

# Optional endpoint override. Default: derive it from IAM_USERS_REGION.
# IAM_USERS_ENDPOINT=https://iam.cn-southwest-2.myhuaweicloud.com

# Fixed integration provider names (not configurable):
# - GitHub OAuth2: github-provider
# - Microsoft 365 OAuth2: m365-provider-common
