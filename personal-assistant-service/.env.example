# LLM Provider
# DeepSeek API key is stored in AgentArts Identity, not in this file.
# Create an API key credential provider named DEEPSEEK_API_KEY.
# MODEL_NAME and MODEL_URL are non-secret overrides for config.yaml.
# MODEL_NAME=deepseek-chat
# MODEL_URL=https://api.deepseek.com

# GitHub OAuth2 (GitHub tools)
# Create an AgentArts OAuth2 credential provider named github-provider.

# Microsoft 365 OAuth2 (Feature 10a email tools)
# Create an AgentArts OAuth2 credential provider named m365-provider.
# The service consumes that provider via @require_access_token and does not
# read Microsoft app client_id/client_secret from runtime environment variables.

# CORS
# Comma-separated allowed Origin list. When unset, service allows the default OBS site.
# CORS_ALLOWED_ORIGINS=https://personal-assistant-web-chat.obs-website.cn-southwest-2.myhuaweicloud.com

# Checkpointer backend
# POSTGRES_DSN=postgresql://user:pass@host:5432/db
# SQLITE_DB_PATH=/path/to/checkpoint.db
